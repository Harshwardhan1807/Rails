<div class="container mt-5">

  <div class="card shadow-sm border-0">
    <div class="card-body p-5">

      <h2 class="mb-4 fw-semibold">Edit User</h2>

      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render "form", user: @user %>

    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= link_to "Back to User Details", user_path(@user), class: "btn btn-outline-dark" %>
    <%= link_to "Back to Users", users_path, class: "btn btn-outline-dark" %>
  </div>

</div>