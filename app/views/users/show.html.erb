<div class="container py-4" style="max-width: 700px;">

  <h2 style="font-weight:500; margin-bottom:1.5rem;">User Details</h2>

  <div class="vn-card p-4 mb-4">
    <div style="font-size:0.9rem; line-height:2.2;">
      <div>Name: &nbsp;<span style="color:#7a7880;"> <%= @user.name %></span></div>
      <div>Email: &nbsp;<span style="color:#7a7880;"> <%= @user.email %></span></div>
      <div>Age: &nbsp;<span style="color:#7a7880;"> <%= @user.age %></span></div>
      <div>Role: &nbsp;
        <span style="background:rgba(224,92,42,0.12); color:#e07a50; font-size:0.8rem; padding:2px 8px; border-radius:4px; text-transform:capitalize;">
          <%= @user.role %>
        </span>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-4">

    <div class="col-md-6">
      <h5 style="color:#7a7880; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.75rem;">
        Subscribed Channels
      </h5>
      <% if @user.channels.empty? %>
        <p style="color:#7a7880; font-size:0.875rem;">No subscribed channels.</p>
      <% else %>
        <div style="border:1px solid rgba(255,255,255,0.07); border-radius:10px; overflow:hidden;">
          <% @user.channels.each_with_index do |channel, i| %>
            <div style="padding:0.75rem 1rem; background:#111116; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">
              <%= link_to channel.name, channel_path(channel),
                          style: "text-decoration:none; font-size:0.875rem;" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="col-md-6">
      <h5 style="color:#7a7880; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.75rem;">
        Owned Channels
      </h5>
      <% if @user.owned_channels.empty? %>
        <p style="color:#7a7880; font-size:0.875rem;">No owned channels.</p>
      <% else %>
        <div style="border:1px solid rgba(255,255,255,0.07); border-radius:10px; overflow:hidden;">
          <% @user.owned_channels.each_with_index do |channel, i| %>
            <div style="padding:0.75rem 1rem; background:#111116; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">
              <%= link_to channel.name, channel_path(channel),
                          style: "text-decoration:none; font-size:0.875rem;" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>

  <div class="d-flex gap-2">
    <%= link_to "Back to Users", users_path(page: params[:page]), class: "vn-btn-outline" %>

    <% if current_user == @user || current_user&.role == "admin" %>
      <%= link_to "Edit", edit_user_registration_path, class: "vn-btn-primary" %>
      <%= button_to "Delete", @user,
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "vn-btn-danger",
                    form: { class: "d-inline" } %>
    <% end %>
  </div>

</div>