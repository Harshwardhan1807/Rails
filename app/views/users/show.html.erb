<div class="container mt-4">

  <h3 class="mb-3">User Details</h3>

  <div class="mb-4">
    <p><strong>Name:</strong> <%= @user.name %></p>
    <p><strong>Email:</strong> <%= @user.email %></p>
    <p><strong>Age:</strong> <%= @user.age %></p>
    <p>
      <strong>Role:</strong>
      <span class="badge bg-primary text-capitalize">
        <%= @user.role %>
      </span>
    </p>
  </div>

  <div class="container mt-3">

    <div class="mb-4">
      <% if @user.channels.empty? %>
        <p class="text-muted">No subscribed channels.</p>
      <% else %>
        <h5 class="mb-3 text-nowrap">Subscribed Channels</h5>
        <ul class="list-group">
          <% @user.channels.each do |channel| %>
            <li class="list-group-item">
              <%= link_to channel.name, channel_path(channel), class: "text-decoration-none" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <div class="mb-4">
      <% if @user.owned_channels.empty? %>
        <p class="text-muted">No owned channels.</p>
      <% else %>
        <h5 class="mb-3 text-nowrap">Owned Channels</h5>
        <ul class="list-group">
          <% @user.owned_channels.each do |channel| %>
            <li class="list-group-item">
              <%= link_to channel.name, channel_path(channel), class: "text-decoration-none" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

  </div>

  <div class="mt-3">
    <% if current_user == @user || current_user&.role == "admin" %>
      <%= link_to "Edit User", edit_user_registration_path, class: "btn btn-warning me-2" %>
      <%= button_to "Delete", @user, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger me-2", form: { style: "display: inline-block;" } %>
    <% end %>

    <%= link_to "Back to Channels", channels_path, class: "btn btn-secondary" %>
  </div>

</div>