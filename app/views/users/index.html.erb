<div class="container py-4" style="max-width: 700px;">

  <h2 style="font-weight:500; margin-bottom:1.5rem;">Users</h2>

  <div style="border:1px solid rgba(255,255,255,0.07); border-radius:10px; overflow:hidden; margin-bottom:1.25rem;">
    <% @users.each_with_index do |user, i| %>
      <div style="padding:0.9rem 1.25rem; background:#111116; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">
        <%= link_to user.name, user_path(user, page: params[:page]),
                    style: "font-weight:500; text-decoration:none; color:#e05c2a;" %>
        <span style="color:#7a7880; font-size:0.8rem; margin-left:6px;"><%= user.email %></span>
      </div>
    <% end %>
  </div>

  <div class="mb-4">
    <%= paginate @users %>
  </div>

  <div class="d-flex gap-2">
    <%= link_to "Channels", channels_path, class: "vn-btn-primary" %>

    <% unless user_signed_in? %>
      <%= link_to "New User", new_user_registration_path, class: "vn-btn-primary" %>
    <% end %>

    <%= link_to "Home", root_path, class: "vn-btn-outline" %>
  </div>

</div>