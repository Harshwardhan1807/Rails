<div class="container mt-4">

  <h1 class="mb-4">Users</h1>

  <ul class="list-group mb-3">
    <% @users.each do |user| %>
      <li class="list-group-item">
        <strong>
          <%= link_to user.name, user_path(user, page: params[:page]), class: "text-decoration-none" %>
        </strong>
        <span class="text-muted">(<%= user.email %>)</span>
      </li>
    <% end %>
  </ul>

  <div class="mb-3">
    <%= paginate @users %>
  </div>

  <div>
    <%= link_to "Channels", channels_path, class: "btn btn-primary me-2" %>

    <% unless user_signed_in? %>
      <%= link_to "New User", new_user_registration_path, class: "btn btn-primary me-2" %>
    <% end %>

    <%= link_to "Home", root_path, class: "btn btn-secondary" %>
  </div>

</div>