<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Streaming" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Streaming">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <style>
      .pagination {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin: 20px 0;
        align-items: center;
      }

      .pagination a,
      .pagination .current {
        display: inline-block;
        padding: 6px 10px;
        border: 1px solid #ddd;
        text-decoration: none;
        color: #2980b9;
        line-height: 1.2;
      }

      .pagination .current {
        background-color: #2980b9;
        color: white;
        border-color: #2980b9;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container-fluid">

        <%= link_to "Streaming Platform", root_path, class: "navbar-brand fw-bold" %>

        <div class="collapse navbar-collapse justify-content-end">

          <% if user_signed_in? %>
            <ul class="navbar-nav align-items-center">

              <li class="nav-item me-3 text-white">
                <span class="small">
                  Logged in as 
                  <strong class="text-info"><%= current_user.name %></strong>
                  <span class="text-secondary">
                    (<%= current_user.role.capitalize %>)
                  </span>
                </span>
              </li>

              <li class="nav-item">
                <%= button_to "Logout",destroy_user_session_path,method: :delete,class: "btn btn-outline-light btn-sm", form: { class: "d-inline" } %>
              </li>

              <li class="nav-item ms-3">
                <%= link_to "My Profile", user_path(current_user), class: "btn btn-primary btn-sm" %>
              </li>

              <li class="nav-item ms-3">
                <%= link_to "All Channels", channels_path, class: "btn btn-primary btn-sm" %>
              </li>

            </ul>
          <% else %>
            <ul class="navbar-nav">
              <li class="nav-item">
                <%= link_to "Login", new_user_session_path, class: "btn btn-primary btn-sm" %>
              </li>
            </ul>
          <% end %>

        </div>
      </div>
    </nav>

    <% if notice %>
      <p class="notice"><%= notice %> 
        <%= link_to "x", "#", onclick: "this.parentElement.style.display='none'; return false;" %>
      </p>
    <% end %>
    <% if alert %>
      <p class="alert"><%= alert %>
        <%= link_to "x", "#", onclick: "this.parentElement.style.display='none'; return false;"  %>
      </p>
    <% end %>
    <%= yield %>
  </body>
</html>
