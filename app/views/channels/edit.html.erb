<div class="container mt-4">

  <h1 class="mb-4">Edit Channel: <%= @channel.name %></h1>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <%= render "form", channel: @channel %>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "Back to Channel", channel_path(@channel), class: "btn btn-secondary" %>
  </div>

</div>