<div class="container py-4" style="max-width: 600px;">

  <h2 style="font-weight:500; margin-bottom:1.5rem;">
    Edit Channel: <span style="color:#7a7880;"><%= @channel.name %></span>
  </h2>

  <div class="vn-card p-4 mb-3">
    <%= render "form", channel: @channel %>
  </div>

  <%= link_to "Back to Channel", channel_path(@channel), class: "vn-btn-outline" %>

</div>