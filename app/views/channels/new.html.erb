<h1>New Channel</h1>

<% if @channel.errors.any? %>
    <h2>Errors:</h2>
    <ul>
        <% @channel.errors.full_messages.each do |message| %>
            <li><%= message %></li>
        <% end %>
    </ul>
<% end %>

<%= form_for @channel do |f| %>
    <p>
        <%= f.label :name %>
        <%= f.text_field :name %>
    </p>
    <p>
        <%= f.label :description %>
        <%= f.text_field :description %>
    </p>
    <p>
        <%= f.label :owner_id %>
        <%= f.text_field :owner_id %>
    </p>
    <p>
        <%= f.submit %>
    </p>
<% end %>

<%= link_to "Back to Channels", channels_path %>