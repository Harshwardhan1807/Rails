<div class="container py-4" style="max-width: 700px;">

  <h2 style="font-family:'DM Sans',sans-serif; font-weight:500; color:#e0ddd8; margin-bottom:1.5rem;">
    Channels
  </h2>

  <div style="border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; overflow: hidden; margin-bottom: 1.25rem;">
    <% @channels.each_with_index do |channel, i| %>
      <div style="padding: 0.9rem 1.25rem; <%= i != 0 ? "border-top: 1px solid rgba(255,255,255,0.06);" : "" %> background: #111116;">
        <%= link_to channel.name, channel_path(channel, page: params[:page]),
                    style: "color:#e05c2a; text-decoration:none; font-size:0.95rem; font-weight:500;" %>
        <% if channel.description.present? %>
          <div style="color:#7a7880; font-size:0.8rem; margin-top:3px;">
            <%= channel.description %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mb-4">
    <%= paginate @channels %>
  </div>

  <div class="d-flex gap-2">
    <% if user_signed_in? && (current_user.admin? || current_user.role == "creator") %>
      <%= link_to "New Channel", new_channel_path, class: "vn-btn-primary" %>
    <% end %>
    <%= link_to "Back to Users", users_path, class: "vn-btn-outline" %>
  </div>

</div>