<div class="container mt-4">

  <h1 class="mb-4 text-center">Channels</h1>

  <ul class="list-group mb-3">
    <% @channels.each do |channel| %>
      <li class="list-group-item">
        <strong>
          <%= link_to channel.name, channel_path(channel, page: params[:page]), class: "text-decoration-none" %>
        </strong>
        <div class="text-muted small">
          <%= channel.description %>
        </div>
      </li>
    <% end %>
  </ul>

  <div class="mb-3">
    <%= paginate @channels %>
  </div>

  <div>
    <% if user_signed_in? && (current_user.role == "admin" || current_user.role == "creator") %>
      <%= link_to "New Channel", new_channel_path, class: "btn btn-primary me-2" %>
    <% end %>

    <%= link_to "Back to Users", users_path, class: "btn btn-secondary" %>
  </div>

</div>