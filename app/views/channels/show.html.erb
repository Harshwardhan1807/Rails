<div class="container py-4" style="max-width: 800px;">

  <div class="vn-card p-4 mb-4">

    <div class="d-flex align-items-start gap-4 mb-3">
      <% if @channel.photo.attached? %>
        <img src="<%= url_for(@channel.photo) %>"
             onclick="openLightbox(this.src)"
             style="width:80px; height:80px; object-fit:cover; border-radius:10px; border:1px solid rgba(255,255,255,0.08); cursor:pointer; flex-shrink:0; transition:transform 0.2s;"
             onmouseover="this.style.transform='scale(1.05)'"
             onmouseout="this.style.transform='scale(1)'">
      <% else %>
        <div style="width:80px; height:80px; border-radius:10px; background:#18181f; border:1px solid rgba(255,255,255,0.07); display:flex; align-items:center; justify-content:center; color:#e05c2a; font-size:2rem; font-weight:600; flex-shrink:0;">
          <%= @channel.name.first.upcase %>
        </div>
      <% end %>

      <div>
        <h2 style="font-weight:500; margin-bottom:0.5rem;"><%= @channel.name %></h2>
        <div style="font-size:0.9rem; line-height:2.2;">
          <div>Description: &nbsp;<span style="color:#7a7880;"><%= @channel.description %></span></div>
          <div>Owner: &nbsp;<span style="color:#7a7880;"><%= @channel.owner.name %></span></div>
          <div>Subscribers: &nbsp;<span style="color:#7a7880;"><%= @channel.subscriptions.count %></span></div>
          <div>Created: &nbsp;<span style="color:#7a7880;"><%= @channel.created_at.strftime("%B %d, %Y") %></span></div>
        </div>
      </div>
    </div>

    <hr style="border-color:rgba(255,255,255,0.07); margin:1.25rem 0;">

    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Back to Channels", channels_path(page: params[:page]), class: "vn-btn-primary" %>

      <% if user_signed_in? && (current_user.admin? || current_user == @channel.owner) %>
        <%= link_to "Edit Channel", edit_channel_path(@channel), class: "vn-btn-primary" %>
        <%= button_to "Delete Channel", channel_path(@channel),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this channel?" },
                      class: "vn-btn-danger",
                      form: { class: "d-inline" } %>
      <% end %>

      <% if user_signed_in? && current_user != @channel.owner %>
        <% if current_user.subscriptions.exists?(channel: @channel) %>
          <%= button_to "Unsubscribe", toggle_subscription_channel_path(@channel),
                        method: :post, class: "vn-btn-danger", form: { class: "d-inline" } %>
        <% else %>
          <%= button_to "Subscribe", toggle_subscription_channel_path(@channel),
                        method: :post, class: "vn-btn-success", form: { class: "d-inline" } %>
        <% end %>
      <% end %>
    </div>
  </div>

  <h5 class="mb-3" style="font-weight:400; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em;">
    Videos
  </h5>

  <% if @channel.videos.any? %>
    <div class="vn-card" style="overflow:hidden;">
      <% @channel.videos.each_with_index do |video, i| %>
        <div style="padding:1.25rem; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">

          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <span style="font-weight:500;"><%= video.title %></span>
              <span style="color:#7a7880; font-size:0.8rem;">(<%= video.duration %> mins)</span>
            </div>
            <% if user_signed_in? && (current_user == @channel.owner || current_user.admin?) %>
              <%= link_to "Edit", edit_channel_video_path(@channel, video), class: "vn-btn-primary" %>
            <% end %>
          </div>

          <% if video.description.present? %>
            <p style="color:#7a7880; font-size:0.85rem; margin-bottom:0.75rem;"><%= video.description %></p>
          <% end %>

          <video width="100%" style="max-width:480px; border-radius:8px;" controls>
            <source src="<%= url_for(video.video_file) %>">
          </video>

          <div style="margin-top:1rem;">

            <div style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; color:#7a7880; margin-bottom:0.75rem;">
              Comments (<%= video.comments.count %>)
            </div>

            <% if video.comments.any? %>
              <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:1rem;">
                <% video.comments.each do |comment| %>
                  <div style="background:#18181f; border:1px solid rgba(255,255,255,0.06); border-radius:8px; padding:0.75rem 1rem;">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <span style="font-size:0.8rem; font-weight:500; color:#e05c2a;">
                          <%= comment.user.name %>
                        </span>
                        <span style="font-size:0.72rem; color:#4a4850; margin-left:8px;">
                          <%= comment.created_at.strftime("%b %d, %Y · %I:%M %p") %>
                        </span>
                        <p style="font-size:0.85rem; margin:0.35rem 0 0;">
                          <%= comment.body %>
                        </p>
                      </div>
                      <% if user_signed_in? && (current_user == comment.user || current_user.admin?) %>
                        <%= button_to "✕", channel_video_comment_path(@channel, video, comment),
                                      method: :delete,
                                      class: "vn-btn-danger",
                                      form: { class: "d-inline" } %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p style="font-size:0.82rem; color:#4a4850; margin-bottom:0.75rem;">No comments yet.</p>
            <% end %>

            <% if user_signed_in? %>
              <%= form_with model: [@channel, video, Comment.new], local: true do |f| %>
                <div style="display:flex; gap:8px; align-items:flex-start;">
                  <%= f.text_area :body,
                                  placeholder: "Write a comment...",
                                  class: "form-control",
                                  rows: 1,
                                  style: "resize:none; font-size:0.875rem;" %>
                  <%= f.submit "Post", class: "vn-btn-primary" %>
                </div>
              <% end %>
            <% end %>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color:#7a7880;">No videos available for this channel.</p>
  <% end %>

  <div class="mt-4" style="text-align:center;">
    <% if user_signed_in? && (current_user.admin? || current_user == @channel.owner) %>
      <%= link_to "New Video", new_channel_video_path(@channel), class: "vn-btn-primary" %>
    <% end %>
  </div>

</div>

<div id="lightbox" onclick="closeLightbox()"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:9999; align-items:center; justify-content:center; cursor:zoom-out;">
  <img id="lightbox-img" style="max-width:90vw; max-height:90vh; border-radius:12px; object-fit:contain;">
</div>

<script>
  function openLightbox(src) {
    document.getElementById("lightbox-img").src = src;
    document.getElementById("lightbox").style.display = "flex";
  }
  function closeLightbox() {
    document.getElementById("lightbox").style.display = "none";
  }
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>