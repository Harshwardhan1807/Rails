<div class="container py-4" style="max-width: 800px;">

  <div class="vn-card p-4 mb-4">

    <h2 style="font-weight:500; margin-bottom:1rem;"><%= @channel.name %></h2>

    <div style="font-size:0.9rem; line-height:2.2;">
      <div>Description: &nbsp;<span style="color:#7a7880;"><%= @channel.description %></span></div>
      <div>Owner: &nbsp;<span style="color:#7a7880;"><%= @channel.owner.name %></span></div>
      <div>Subscribers: &nbsp;<span style="color:#7a7880;"><%= @channel.subscriptions.count %></span></div>
      <div>Created: &nbsp;<span style="color:#7a7880;"><%= @channel.created_at.strftime("%B %d, %Y") %></span></div>
    </div>

    <hr style="border-color:rgba(255,255,255,0.07); margin:1.25rem 0;">

    <div class="d-flex flex-wrap gap-2">
      <%= link_to "Back to Channels", channels_path(page: params[:page]), class: "vn-btn-primary" %>

      <% if user_signed_in? && (current_user.admin? || current_user == @channel.owner) %>
        <%= link_to "Edit Channel", edit_channel_path(@channel), class: "vn-btn-primary" %>
      <% end %>

      <% if user_signed_in? && current_user != @channel.owner %>
        <% if current_user.subscriptions.exists?(channel: @channel) %>
          <%= button_to "Unsubscribe", toggle_subscription_channel_path(@channel),
                        method: :post, class: "vn-btn-danger", form: { class: "d-inline" } %>
        <% else %>
          <%= button_to "Subscribe", toggle_subscription_channel_path(@channel),
                        method: :post, class: "vn-btn-success", form: { class: "d-inline" } %>
        <% end %>
      <% end %>
    </div>
  </div>

  <h5 class="mb-3" style="font-weight:400; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em;">
    Videos
  </h5>

  <% if @channel.videos.any? %>
    <div class="vn-card" style="overflow:hidden;">
      <% @channel.videos.each_with_index do |video, i| %>
        <div style="padding:1.25rem; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">

          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <span style="font-weight:500;"><%= video.title %></span>
              <span style="color:#7a7880; font-size:0.8rem;">(<%= video.duration %> mins)</span>
            </div>
            <% if user_signed_in? && (current_user == @channel.owner || current_user.admin?) %>
              <%= link_to "Edit", edit_channel_video_path(@channel, video), class: "vn-btn-primary" %>
            <% end %>
          </div>

          <% if video.description.present? %>
            <p style="color:#7a7880; font-size:0.85rem; margin-bottom:0.75rem;"><%= video.description %></p>
          <% end %>

          <video width="100%" style="max-width:480px; border-radius:8px;" controls>
            <source src="<%= url_for(video.video_file) %>">
          </video>

        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color:#7a7880;">No videos available for this channel.</p>
  <% end %>

  <div class="mt-4" style="text-align: center;">
    <% if user_signed_in? && (current_user.admin? || current_user == @channel.owner) %>
      <%= link_to "New Video", new_channel_video_path(@channel), class: "vn-btn-primary" %>
    <% end %>
  </div>
</div>