<div class="container mt-4">

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">

      <h2 class="mb-3"><%= @channel.name %></h2>

      <p class="mb-2"><strong>Description:</strong> <%= @channel.description %></p>
      <p class="mb-2"><strong>Owner:</strong> <%= @channel.owner.name %></p>
      <p class="mb-2"><strong>Subscribers:</strong> <%= @channel.subscriptions.count %></p>
      <p class="mb-3"><strong>Created At:</strong> <%= @channel.created_at.strftime("%B %d, %Y") %></p>

      <% if user_signed_in? && (current_user.admin? || current_user == @channel.owner) %>
        <div class="d-flex gap-2 mb-3">
          <%= link_to "Edit Channel", edit_channel_path(@channel), class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "New Video", new_channel_video_path(@channel), class: "btn btn-outline-success btn-sm" %>
        </div>
      <% end %>

      <div class="d-flex gap-2">
        <%= link_to "Back to Channels", channels_path(page: params[:page]), class: "btn btn-secondary btn-sm" %>
        <% if user_signed_in? && current_user.subscriptions.exists?(channel: @channel) %>
          <%= button_to "Unsubscribe", toggle_subscription_channel_path(@channel), method: :post, class: "btn btn-danger btn-sm" %>
        <% elsif user_signed_in? %>
          <%= button_to "Subscribe", toggle_subscription_channel_path(@channel), method: :post, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>

    </div>
  </div>

  <h4 class="mb-3">Videos</h4>
  <% if @channel.videos.any? %>
    <ul class="list-group">
      <% @channel.videos.each do |video| %>
        <li class="list-group-item">

          <div class="d-flex justify-content-between">
            <div>
              <strong><%= video.title %></strong>
              <span class="text-muted">(<%= video.duration %> mins)</span>
            </div>
            <% if user_signed_in? && (current_user == @channel.owner || current_user.admin?) %>
              <%= link_to "Edit", edit_channel_video_path(@channel, video), class: "btn btn-sm btn-outline-primary" %>
            <% end %>
          </div>

          <p class="text-muted">
            <%= video.description %>
          </p>
          
          <div class="mt-2">
            <video width="420" controls>
              <source src="<%= url_for(video.video_file) %>">
            </video>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted">No videos available for this channel.</p>
  <% end %>

</div>