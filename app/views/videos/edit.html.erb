<h1>Edit Video: <%= @video.title %></h1>

<% if @video.errors.any? %>
    <h2>Errors:</h2>
    <ul>
        <% @video.errors.full_messages.each do |message| %>
            <li><%= message %></li>
        <% end %>
    </ul>
<% end %>



<%= form_with model: [@channel, @video], class: "w-100" do |form| %>

  <div class="row mb-3">
    <div class="col-md-6">
      <%= form.label :title, class: "form-label fw-semibold" %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :duration, "Duration (minutes)", class: "form-label fw-semibold" %>
      <%= form.number_field :duration, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label fw-semibold" %>
    <%= form.text_area :description, class: "form-control", rows: 4 %>
  </div>

  <div class="mb-4">
    <%= form.label :video_file, class: "form-label fw-semibold" %>
    <p class="text-muted small">
      Current file: <strong><%= @video.video_file.filename %></strong>
    </p>

    <%= form.file_field :video_file, class: "form-control" %>
  </div>
  
  <div class="d-flex gap-2 align-items-center">
    <%= form.submit "Update Video", class: "btn btn-primary px-4" %>
    <%= link_to "Back to Channel", channel_path(@channel), class: "btn btn-secondary ms-2" %>
    
  <% end %>

    <%= button_to "Delete Video", channel_video_path(@channel, @video), method: :delete, data: { confirm: "Are you sure you want to delete this video?" }, class: "btn btn-danger ms-2" %>
  </div>