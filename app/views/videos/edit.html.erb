<div class="container py-4" style="max-width: 700px;">

  <h2 style="font-weight:500; margin-bottom:1.5rem;">
    Edit Video: <span style="color:#e05c2a;"><%= @video.title %></span>
  </h2>

  <div class="vn-card p-4">

    <% if @video.errors.any? %>
      <div style="background:rgba(239,83,80,0.08); border:1px solid rgba(239,83,80,0.2); border-radius:8px; padding:1rem; margin-bottom:1.25rem; font-size:0.875rem; color:#ef5350;">
        <div style="margin-bottom:0.5rem;">Please fix the following errors:</div>
        <ul style="margin:0; padding-left:1.25rem;">
          <% @video.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: [@channel, @video] do |form| %>

      <div class="row mb-3">
        <div class="col-md-6">
          <%= form.label :title, class: "form-label" %>
          <%= form.text_field :title, class: "form-control" %>
        </div>

        <div class="col-md-6">
          <%= form.label :duration, "Duration (minutes)", class: "form-label" %>
          <%= form.number_field :duration, class: "form-control" %>
        </div>
      </div>

      <div class="mb-3">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, class: "form-control", rows: 4 %>
      </div>

      <div class="mb-4">
        <%= form.label :video_file, "Video File (MP4)", class: "form-label" %>
        <p class="text-muted small mb-2">
          Current file: <strong><%= @video.video_file.filename %></strong>
        </p>
        <%= form.file_field :video_file, class: "form-control" %>
      </div>

      <div class="d-flex gap-2">
        <%= form.submit "Update Video", class: "vn-btn-primary" %>
        <%= link_to "Back to Channel", channel_path(@channel), class: "vn-btn-outline" %>
    <% end %>

        <%= button_to "Delete Video",
                      channel_video_path(@channel, @video),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this video?" },
                      class: "vn-btn-danger" %>
      </div>

  </div>

</div>