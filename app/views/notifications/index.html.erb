<div class="container mt-4">

  <h3 class="mb-3">Notifications</h3>

  <% if @notifications.empty? %>
    <p class="text-muted">No notifications available.</p>
  <% else %>
    <ul class="list-group">
      <% @notifications.each do |n| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <p class="mb-1 <%= "fw-bold" unless n.read %>">
                    <%= n.message %>
                </p>
                <% unless n.read %>
                    <span class="badge bg-warning text-dark">Unread</span>
                <% else %>
                    <span class="badge bg-success">Read</span>
                <% end %>

                <% unless n.read %>
                    <%= button_to "Mark as read", mark_as_read_notification_path(n),
                                  method: :patch,
                                  class: "btn btn-sm btn-primary ms-3 badge",
                                  form: { style: "display: inline;" } %>
                <% end %>
                <%= button_to "Delete", notification_path(n), method: :delete, class: "btn btn-sm btn-danger ms-3 badge", form: { style: "display: inline;" } %>
                <div>
                    <small class="text-muted">
                        <%= n.created_at.strftime("%B %d, %Y %I:%M %p") %>
                    </small>
                </div>
            </div>
        </li>
        
      <% end %>
    </ul>

  <% end %>

</div>