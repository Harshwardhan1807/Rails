<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:500; margin:0;">Movies</h2>
    <%= link_to "Top Movies", top_movies_path, class: "vn-btn-outline" %>
  </div>

  <%= form_with url: movies_path, method: :get, local: true, class: "mb-4" do %>
    <div style="display:flex; gap:8px;">
      <%= text_field_tag :query, params[:query],
                         class: "form-control",
                         placeholder: "Search movies..." %>
      <button type="submit" class="vn-btn-primary">Search</button>
    </div>
  <% end %>

  <div style="border:1px solid rgba(255,255,255,0.07); border-radius:10px; overflow:hidden;">
    <% @movies.each_with_index do |movie, i| %>
      <div style="padding:1rem 1.25rem; background:#111116; <%= i != 0 ? "border-top:1px solid rgba(255,255,255,0.06);" : "" %>">
        <div class="d-flex align-items-center gap-3">

          <div style="width:64px; height:90px; flex-shrink:0; border-radius:8px; overflow:hidden; border:1px solid rgba(255,255,255,0.07);">
            <% if movie.poster_url.present? %>
              <img src="<%= movie.poster_url %>"
                   style="width:100%; height:100%; object-fit:cover;"
                   onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:#18181f;display:flex;align-items:center;justify-content:center;color:#4a4850;font-size:0.7rem;\'>No Image</div>';">
            <% else %>
              <div style="width:100%; height:100%; background:#18181f; display:flex; align-items:center; justify-content:center; color:#4a4850; font-size:0.7rem;">
                No Image
              </div>
            <% end %>
          </div>

          <div style="flex:1;">
            <div style="font-weight:500; margin-bottom:0.25rem;"><%= movie.title %></div>
            <div style="color:#e05c2a; font-size:0.8rem; margin-bottom:0.25rem;">⭐ <%= movie.rating %></div>
            <div style="color:#7a7880; font-size:0.8rem;"><%= truncate(movie.description, length: 100) %></div>
          </div>

          <%= link_to "View", movie_path(movie), class: "vn-btn-primary" %>

        </div>
      </div>
    <% end %>
  </div>
  <div class="d-flex justify-content-between align-items-center mt-4">
    <div style="text-align:center; flex:1;">
        <%= paginate @movies %>
    </div>
  </div>

</div>