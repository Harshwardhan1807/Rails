<h2 class="mb-3">Top Movies</h2>

<div class="row">
  <% @movies.each do |movie| %>
    <div class="col-md-3 mb-4">
      <div class="card h-100 shadow-sm d-flex flex-column">

        <div style="height: 250px; overflow: hidden;">
          <% if movie.poster_url.present? %>
            <img src="<%= movie.poster_url %>"
                 class="w-100 h-100"
                 style="object-fit: cover;"
                 onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'d-flex align-items-center justify-content-center h-100 bg-secondary text-white\'>No Image</div>';">
          <% else %>
            <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white">
              No Image
            </div>
          <% end %>
        </div>

        <div class="card-body d-flex flex-column">

          <h6 class="fw-bold mb-2" style="min-height: 40px;">
            <%= movie.title %>
          </h6>

          <p class="text-muted small mb-1">
            ⭐ <%= movie.rating %>
          </p>

          <p class="small text-muted flex-grow-1">
            <%= truncate(movie.description, length: 80) %>
          </p>

          <%= link_to "View", movie_path(movie), class: "btn btn-sm btn-dark mt-auto" %>

        </div>

      </div>
    </div>
  <% end %>
</div>

<%= link_to "View All Movies", movies_path, class: "btn btn-outline-dark" %>