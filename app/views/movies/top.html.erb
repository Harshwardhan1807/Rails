<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:500; margin:0;">Top Movies</h2>
    <%= link_to "View All Movies", movies_path, class: "vn-btn-outline" %>
  </div>

  <div class="row g-3">
    <% @movies.each do |movie| %>
      <div class="col-md-3 col-sm-6">
        <div style="background:#111116; border:1px solid rgba(255,255,255,0.07); border-radius:10px; overflow:hidden; height:100%; display:flex; flex-direction:column;">

          <div style="height:220px; overflow:hidden;">
            <% if movie.poster_url.present? %>
              <img src="<%= movie.poster_url %>"
                   style="width:100%; height:100%; object-fit:cover;"
                   onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;background:#18181f;display:flex;align-items:center;justify-content:center;color:#4a4850;font-size:0.8rem;\'>No Image</div>';">
            <% else %>
              <div style="width:100%; height:100%; background:#18181f; display:flex; align-items:center; justify-content:center; color:#4a4850; font-size:0.8rem;">
                No Image
              </div>
            <% end %>
          </div>

          <div style="padding:1rem; display:flex; flex-direction:column; flex:1;">
            <div style="font-weight:500; font-size:0.9rem; margin-bottom:0.35rem;"><%= movie.title %></div>
            <div style="color:#e05c2a; font-size:0.78rem; margin-bottom:0.35rem;">⭐ <%= movie.rating %></div>
            <div style="color:#7a7880; font-size:0.78rem; flex:1; margin-bottom:0.75rem;"><%= truncate(movie.description, length: 80) %></div>
            <%= link_to "View", movie_path(movie), class: "vn-btn-primary", style: "text-align:center;" %>
          </div>

        </div>
      </div>
    <% end %>
  </div>

</div>