<h2>Sign Up</h2>
<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <p>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </p>
  <p>
    <%= f.label :email %>
    <%= f.text_field :email, autocomplete: "email" %>
  </p>
  <p>
    <%= f.label :password %>
    <%= f.password_field :password, autocomplete: "new-password" %>
  </p>
  <p>
    <%= f.label :age %>
    <%= f.number_field :age %>
  </p>
  <p>
    <%= f.label :role %>
    <%= f.select :role, options_for_select([["Creator", "creator"], ["Viewer", "viewer"]]) %>
  </p>
  <p>
    <%= f.submit "Sign up" %> | <%= link_to "Back", users_path %>
  </p>
<% end %>